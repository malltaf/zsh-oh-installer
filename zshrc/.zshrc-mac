export PATH="$HOME/.local/bin:/usr/local/sbin:$PATH"

# Cursor agent: lightweight zsh without oh-my-zsh.
if [[ -n "$CURSOR_AGENT" ]]; then
  return
fi

# Variables filled in by the installer.
export ZSH_USER_M=__ZSH_USER_M__
export ZSH_DEFAULT_THEME=__ZSH_DEFAULT_THEME__

# Path to your oh-my-zsh installation.
export ZSH="$ZSH_USER_M/.oh-my-zsh"

ZSH_THEME="$ZSH_DEFAULT_THEME"

# Would you like to use another custom folder than $ZSH/custom?
ZSH_CUSTOM=$ZSH_USER_M/.oh-my-zsh/custom/

# Skip compaudit's fpath-permission scan (~60-100ms per shell start).
# Safe on a single-user machine; remove on shared/multi-user boxes.
ZSH_DISABLE_COMPFIX="true"

# Add wisely, as too many plugins slow down shell startup.
# fast-syntax-highlighting MUST stay last (it wraps ZLE widgets).
plugins=(
  command-not-found git last-working-dir sudo wd zsh-autosuggestions k you-should-use macos fast-syntax-highlighting
)
source $ZSH/oh-my-zsh.sh

# Paste speed: see zshrc-linux for the full explanation. fsh sets MAXLENGTH=10000
# on load, so these must come after oh-my-zsh.sh.
ZSH_HIGHLIGHT_MAXLENGTH=1500
ZSH_AUTOSUGGEST_CLEAR_WIDGETS+=(bracketed-paste)

# Root cause of slow pasting: oh-my-zsh's bracketed-paste-magic re-inserts pasted
# text char-by-char. During a paste, swap self-insert to its pre-plugin form so
# pasted chars skip the wrappers, then restore it.
# https://github.com/zsh-users/zsh-autosuggestions/issues/238
_paste_speedup_init() {
  typeset -g _PASTE_SPEEDUP_OLD_SELF_INSERT=${${(s.:.)widgets[self-insert]}[2,3]}
  zle -N self-insert url-quote-magic
}
_paste_speedup_finish() {
  zle -N self-insert $_PASTE_SPEEDUP_OLD_SELF_INSERT
}
zstyle :bracketed-paste-magic paste-init _paste_speedup_init
zstyle :bracketed-paste-magic paste-finish _paste_speedup_finish

autoload -U up-line-or-beginning-search
autoload -U down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey "^[[A" up-line-or-beginning-search # Up
bindkey "^[[B" down-line-or-beginning-search # Down

# Aliases
alias zshconfig="micro ~/.zshrc"
alias p8="ping 8.8.8.8"
alias pya="ping ya.ru"
alias n="nano"
alias m="micro"
alias v="vim"
alias dps="docker ps"
alias dpsa="docker ps -a"
alias dpsi="docker images"
alias dst="docker stats"
alias drun="docker run -d"
alias dexec="docker exec -it"
alias dstop="docker stop"
alias drm="docker rm"
alias drmi="docker rmi"
alias ll="k -ah"
alias llt="k -Aht"
alias ssha='eval `ssh-agent -s`'
alias java-15="export JAVA_HOME=\`/usr/libexec/java_home -v 15\`; java -version"
alias java-8="export JAVA_HOME=\`/usr/libexec/java_home -v 1.8\`; java -version"

# fzf: fuzzy history (Ctrl+R), file find (Ctrl+T), cd (Alt+C).
# Homebrew-free install generates ~/.fzf.zsh.
[ -f "$HOME/.fzf.zsh" ] && source "$HOME/.fzf.zsh"
